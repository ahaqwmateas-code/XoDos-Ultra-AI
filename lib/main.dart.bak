  Future<void> _ae(List<Map<String, dynamic>> _af) async {
    final SharedPreferences _ag = await SharedPreferences.getInstance();
    await _ag.setString('xodos_profiles', jsonEncode(_af));
  }

  void _ah(int _ai) {
    setState(() {
      _b.removeAt(_ai);
