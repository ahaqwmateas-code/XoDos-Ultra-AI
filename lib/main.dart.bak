          ],
        ),
      );
    }
  }

  Future<void> _v() async {
    try {
      final String _w = '${(await getTemporaryDirectory()).path}/recording_${DateTime.now().millisecondsSinceEpoch}.m4a';
      await _c.start(
        const RecordConfig(encoder: AudioEncoder.aacLc, bitRate: 128000, sampleRate: 44100),
        path: _w,
      );
      setState(() {
        _e = true;
      });
      debugPrint('');
    } catch (e) {
      debugPrint('');
    }
  }

  Future<void> _x() async {
    try {
      final String? _y = await _c.stop();
      if (_y != null) {
        setState(() {
          _e = false;
          _f = 0.0;
        });
        if (!mounted) return;
        ScaffoldMessenger.of(context).showSnackBar(
          const SnackBar(content: Text('Recording saved')),
        );
      }
    } catch (e) {
      debugPrint('');
    }
  }

  void _z(String _aa, String _ab, String _ac) {
    final Map<String, dynamic> _ad = {
      'name': _aa,
      'host': _ab,
      'port': _ac,
      'created': DateTime.now().toIso8601String(),
    };
    setState(() {
      _b.add(_ad);
    });
    _ae(_b);
